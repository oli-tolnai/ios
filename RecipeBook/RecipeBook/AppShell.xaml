<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RecipeBook.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RecipeBook.Views"
    Title="RecipeBook">

    <TabBar>
        <ShellContent
            Title="Keresés"
            ContentTemplate="{DataTemplate views:SearchPage}" />
        <ShellContent
            Title="Kedvencek"
            ContentTemplate="{DataTemplate views:FavoritesPage}" />
        <ShellContent
            Title="Saját"
            ContentTemplate="{DataTemplate views:MyRecipesPage}" />
    </TabBar>

</Shell>
