<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeBook.Views.FavoritesPage"
             x:Name="FavoritesPageRoot"
             Title="Kedvencek">
    <Grid Padding="16" RowDefinitions="*,Auto">
        <CollectionView Grid.Row="0" SelectionMode="None" ItemsSource="{Binding Favorites}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6" Padding="10" BackgroundColor="White" BorderColor="#E0E0E0">
                        <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                            <Image Grid.Column="0" WidthRequest="60" HeightRequest="60" Aspect="AspectFill" Source="{Binding ThumbnailUrl}" />
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="2">
                                <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label Text="{Binding Category}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Grid.Row="1" Spacing="6">
                                <Button Text="Megnyit"
                                        FontSize="11"
                                        Padding="10,6"
                                        MinimumHeightRequest="34"
                                        Command="{Binding BindingContext.NavigateToDetailCommand, Source={x:Reference FavoritesPageRoot}}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Megoszt"
                                        FontSize="11"
                                        Padding="10,6"
                                        MinimumHeightRequest="34"
                                        Command="{Binding BindingContext.ShareRecipeCommand, Source={x:Reference FavoritesPageRoot}}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Törlés"
                                        FontSize="11"
                                        Padding="10,6"
                                        MinimumHeightRequest="34"
                                        Command="{Binding BindingContext.DeleteFavoriteCommand, Source={x:Reference FavoritesPageRoot}}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="1"
               HorizontalOptions="Center"
               Text="Még nincsenek mentett receptek."
               IsVisible="{Binding IsEmpty}" />
    </Grid>
</ContentPage>
