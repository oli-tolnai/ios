<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeBook.Views.SearchPage"
             x:Name="SearchPageRoot"
             Title="Recept keresés">
    <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,*,Auto">
        <Label Grid.Row="0"
               Text="Nincs internetkapcsolat."
               TextColor="Red"
               IsVisible="{Binding IsOffline}" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,8,0,0">
            <Entry Grid.Column="0"
                   Placeholder="Keresés..."
                   Text="{Binding SearchQuery}"
                   IsEnabled="{Binding CanSearch}"
                   ReturnCommand="{Binding SearchCommand}" />
            <Button Grid.Column="1"
                    Text="Keresés"
                    Command="{Binding SearchCommand}"
                    IsEnabled="{Binding CanSearch}" />
        </Grid>

        <ActivityIndicator Grid.Row="2"
                           Margin="0,8,0,8"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}" />

        <CollectionView Grid.Row="3"
                        SelectionMode="None"
                        ItemsSource="{Binding SearchResults}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6" Padding="10" BackgroundColor="White" BorderColor="#E0E0E0">
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <Image Grid.Column="0"
                                   WidthRequest="70"
                                   HeightRequest="70"
                                   Aspect="AspectFill"
                                   Source="{Binding StrMealThumb}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding StrMeal}" FontAttributes="Bold" TextColor="#1F2937" />
                                <Label Text="{Binding StrCategory}" FontSize="12" TextColor="#6B7280" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="Részletek"
                                    FontSize="12"
                                    Command="{Binding BindingContext.OpenDetailCommand, Source={x:Reference SearchPageRoot}}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="4"
               Text="Nincs találat."
               HorizontalOptions="Center"
               IsVisible="{Binding HasNoResults}" />
    </Grid>
</ContentPage>
