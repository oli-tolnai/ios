<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeBook.Views.RecipeDetailPage"
             Title="Recept részletei">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <HorizontalStackLayout Spacing="8">
                <Button Text="Vissza" Command="{Binding GoBackCommand}" />
                <Button Text="{Binding FavoriteButtonText}"
                        IsVisible="{Binding CanToggleFavorite}"
                        Command="{Binding ToggleFavoriteCommand}" />
                <Button Text="Megosztás" Command="{Binding ShareRecipeCommand}" />
            </HorizontalStackLayout>

            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="24" />

            <Image Source="{Binding ImageSource}" HeightRequest="220" Aspect="AspectFill" />

            <Label Text="{Binding Category}" TextColor="Gray" />

            <Label Text="Hozzávalók" FontAttributes="Bold" />
            <Label Text="{Binding Ingredients}" />

            <Label Text="Elkészítés" FontAttributes="Bold" Margin="0,8,0,0" />
            <Label Text="{Binding Instructions}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
